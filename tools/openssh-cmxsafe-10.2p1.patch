+static int
+cmxsafe_user_to_ipv6(const struct passwd *pw, char *buf, size_t buflen,
+    struct in6_addr *addrp)
+{
+	char canonical[33];
+	size_t i;
+
+	if (pw == NULL || pw->pw_name == NULL || buf == NULL ||
+	    strlen(pw->pw_name) != 32 || buflen < INET6_ADDRSTRLEN)
+		return -1;
+	for (i = 0; i < 32; i++) {
+		char ch = pw->pw_name[i];
+
+		if (ch >= 'A' && ch <= 'F')
+			ch = ch - 'A' + 'a';
+		if (!((ch >= '0' && ch <= '9') || (ch >= 'a' && ch <= 'f')))
+			return -1;
+		canonical[i] = ch;
+	}
+	canonical[32] = '\0';
+	snprintf(buf, buflen, "%.*s:%.*s:%.*s:%.*s:%.*s:%.*s:%.*s:%.*s",
+	    4, canonical + 0, 4, canonical + 4, 4, canonical + 8,
+	    4, canonical + 12, 4, canonical + 16, 4, canonical + 20,
+	    4, canonical + 24, 4, canonical + 28);
+	if (addrp != NULL && inet_pton(AF_INET6, buf, addrp) != 1)
+		return -1;
+	return 0;
+}
+
+static int
+cmxsafe_rfwd_listen_matches_user(const struct passwd *pw,
+    const char *listen_host, char *canonical, size_t canonical_len)
+{
+	struct in6_addr expected, requested;
+
+	if (cmxsafe_user_to_ipv6(pw, canonical, canonical_len, &expected) != 0)
+		return 1;
+	if (listen_host == NULL || *listen_host == '\0' ||
+	    strcmp(listen_host, "*") == 0 ||
+	    strcmp(listen_host, "localhost") == 0)
+		return 0;
+	if (inet_pton(AF_INET6, listen_host, &requested) != 1)
+		return 0;
+	return memcmp(&expected, &requested, sizeof(expected)) == 0;
+}
+
+static int
+cmxsafe_ensure_canonical_ready(struct ssh *ssh, const struct passwd *pw)
+{
+	char canonical[INET6_ADDRSTRLEN], *hook, *argv[4];
+	struct in6_addr addr;
+	pid_t pid;
+	int required = 0, status;
+
+	if (cmxsafe_canonical_ready)
+		return 0;
+	if (cmxsafe_user_to_ipv6(pw, canonical, sizeof(canonical), &addr) != 0)
+		return 0;
+
+	hook = getenv("CMXSAFE_CANONICAL_READY_HOOK");
+	if (hook != NULL && *hook != '\0')
+		required = 1;
+	else
+		hook = "/opt/ssh-policy/ensure-canonical-ready.sh";
+	if (access(hook, X_OK) != 0) {
+		if (required) {
+			error("CMXsafe canonical readiness hook %.200s is not "
+			    "executable: %s", hook, strerror(errno));
+			ssh_packet_send_debug(ssh, "CMXsafe canonical IPv6 "
+			    "readiness hook is not available.");
+			return -1;
+		}
+		debug3("CMXsafe canonical readiness hook %.200s is not "
+		    "available; forwarding without server-side wait", hook);
+		cmxsafe_canonical_ready = 1;
+		return 0;
+	}
+
+	debug("CMXsafe waiting for canonical IPv6 %.100s for user %.100s",
+	    canonical, pw->pw_name);
+	switch ((pid = fork())) {
+	case -1:
+		error("fork CMXsafe canonical readiness hook: %s",
+		    strerror(errno));
+		return -1;
+	case 0:
+		argv[0] = hook;
+		argv[1] = pw->pw_name;
+		argv[2] = canonical;
+		argv[3] = NULL;
+		execv(hook, argv);
+		_exit(127);
+	}
+	while (waitpid(pid, &status, 0) == -1) {
+		if (errno == EINTR)
+			continue;
+		error("wait CMXsafe canonical readiness hook: %s",
+		    strerror(errno));
+		return -1;
+	}
+	if (WIFEXITED(status) && WEXITSTATUS(status) == 0) {
+		cmxsafe_canonical_ready = 1;
+		return 0;
+	}
+	error("CMXsafe canonical readiness hook failed for user %.100s",
+	    pw->pw_name);
+	ssh_packet_send_debug(ssh, "CMXsafe canonical IPv6 is not ready.");
+	return -1;
+}

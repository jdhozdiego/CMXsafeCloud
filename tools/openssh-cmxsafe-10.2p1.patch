+static int
+cmxsafe_is_loopback_host(const char *host)
+{
+	return host != NULL &&
+	    (strcmp(host, "::1") == 0 || strcmp(host, "127.0.0.1") == 0);
+}
+
+static int
+cmxsafe_user_to_ipv6(char *buf, size_t buflen)
+{
+	struct passwd *pw;
+	char canonical[33];
+	size_t i;
+
+	if (buflen < 40)
+		return -1;
+	if ((pw = getpwuid(geteuid())) == NULL || pw->pw_name == NULL)
+		return -1;
+	if (strlen(pw->pw_name) != 32)
+		return -1;
+	for (i = 0; i < 32; i++) {
+		char ch = pw->pw_name[i];
+
+		if (ch >= 'A' && ch <= 'F')
+			ch = ch - 'A' + 'a';
+		if (!((ch >= '0' && ch <= '9') || (ch >= 'a' && ch <= 'f')))
+			return -1;
+		canonical[i] = ch;
+	}
+	canonical[32] = '\0';
+	snprintf(buf, buflen, "%.*s:%.*s:%.*s:%.*s:%.*s:%.*s:%.*s:%.*s",
+	    4, canonical + 0, 4, canonical + 4, 4, canonical + 8,
+	    4, canonical + 12, 4, canonical + 16, 4, canonical + 20,
+	    4, canonical + 24, 4, canonical + 28);
+	return 0;
+}
+
+static int
+cmxsafe_resolve_bind_host(const struct channel_connect *cctx,
+    char *bind_host, size_t bind_host_len, const char **scopep)
+{
+	struct in6_addr addr;
+
+	if (scopep != NULL)
+		*scopep = "peer";
+	if (cctx == NULL || bind_host == NULL || bind_host_len == 0 ||
+	    cctx->host_orig == NULL || *cctx->host_orig == '\0')
+		return 0;
+	if (cmxsafe_is_loopback_host(cctx->host)) {
+		if (inet_pton(AF_INET6, cctx->host_orig, &addr) != 1)
+			return 0;
+		strlcpy(bind_host, cctx->host_orig, bind_host_len);
+		return 1;
+	}
+	if (cmxsafe_user_to_ipv6(bind_host, bind_host_len) != 0) {
+		debug2_f("unable to derive canonical IPv6 from current user");
+		return 0;
+	}
+	if (scopep != NULL)
+		*scopep = "self";
+	return 1;
+}
+
+static int
+cmxsafe_endpointd_ensure(const char *scope, const char *ipv6, u_int port_orig,
+    int sock)
+{
+	const char *sock_path;
+	struct sockaddr_un sunaddr;
+	char request[256], response[256], owner_id[CMXSAFE_OWNER_ID_LEN];
+	size_t used = 0;
+	ssize_t nr;
+	int fd = -1, ok = -1;
+
+	if ((sock_path = getenv(CMXSAFE_ENDPOINTD_SOCK_ENV)) == NULL ||
+	    *sock_path == '\0')
+		return 0;
+	if (strlen(sock_path) >= sizeof(sunaddr.sun_path)) {
+		error_f("endpoint helper socket path is too long");
+		return -1;
+	}
+	if (snprintf(owner_id, sizeof(owner_id), "%s:pid:%ld:port:%u:fd:%d",
+	    scope != NULL ? scope : "peer", (long)getpid(), port_orig, sock) >=
+	    (int)sizeof(owner_id)) {
+		error_f("failed to format endpoint helper owner id");
+		return -1;
+	}
+	if (snprintf(request, sizeof(request), "ensure\t%s\t%s\t%s\n",
+	    scope != NULL ? scope : "peer", owner_id, ipv6) >=
+	    (int)sizeof(request)) {
+		error_f("endpoint helper request would overflow");
+		return -1;
+	}
+	if ((fd = socket(AF_UNIX, SOCK_STREAM, 0)) == -1) {
+		error_f("socket(AF_UNIX): %s", strerror(errno));
+		return -1;
+	}
+	memset(&sunaddr, 0, sizeof(sunaddr));
+	sunaddr.sun_family = AF_UNIX;
+	strlcpy(sunaddr.sun_path, sock_path, sizeof(sunaddr.sun_path));
+	if (connect(fd, (struct sockaddr *)&sunaddr, sizeof(sunaddr)) == -1) {
+		error_f("connect(%s): %s", sock_path, strerror(errno));
+		goto out;
+	}
+	if (atomicio(vwrite, fd, request, strlen(request)) != strlen(request)) {
+		error_f("endpoint helper write failed: %s", strerror(errno));
+		goto out;
+	}
+	memset(response, 0, sizeof(response));
+	while (used < sizeof(response) - 1) {
+		nr = read(fd, response + used, sizeof(response) - 1 - used);
+		if (nr == -1) {
+			if (errno == EINTR)
+				continue;
+			error_f("endpoint helper read failed: %s", strerror(errno));
+			goto out;
+		}
+		if (nr == 0)
+			break;
+		used += (size_t)nr;
+		if (response[used - 1] == '\n')
+			break;
+	}
+	if (strstr(response, "\"ok\": true") == NULL &&
+	    strstr(response, "\"ok\":true") == NULL) {
+		error_f("endpoint helper rejected ensure for %s: %s",
+		    ipv6, response);
+		goto out;
+	}
+	ok = 0;
+ out:
+	if (fd != -1)
+		close(fd);
+	return ok;
+}
+
+static int
+channel_connect_bind_source(int sock, const struct channel_connect *cctx)
+{
+	struct sockaddr_in6 bind_addr;
+	char bind_host[INET6_ADDRSTRLEN];
+	const char *scope = "peer";
+	int on = 1;
+
+	if (cctx == NULL || cctx->ai == NULL || cctx->ai->ai_family != AF_INET6 ||
+	    cctx->port_orig == 0)
+		return 0;
+	if (!cmxsafe_resolve_bind_host(cctx, bind_host, sizeof(bind_host), &scope))
+		return 0;
+	if (cmxsafe_endpointd_ensure(scope, bind_host, cctx->port_orig, sock) != 0)
+		return -1;
+	memset(&bind_addr, 0, sizeof(bind_addr));
+	bind_addr.sin6_family = AF_INET6;
+	bind_addr.sin6_port = htons(cctx->port_orig);
+	if (inet_pton(AF_INET6, bind_host, &bind_addr.sin6_addr) != 1) {
+		error_f("invalid bind host %s", bind_host);
+		errno = EINVAL;
+		return -1;
+	}
+	if (setsockopt(sock, SOL_SOCKET, SO_REUSEADDR, &on, sizeof(on)) == -1) {
+		error_f("setsockopt(SO_REUSEADDR): %s", strerror(errno));
+		return -1;
+	}
+	if (bind(sock, (struct sockaddr *)&bind_addr, sizeof(bind_addr)) == -1) {
+		error_f("bind([%s]:%u): %s", bind_host, cctx->port_orig,
+		    strerror(errno));
+		return -1;
+	}
+	debug2_f("bound forwarding source to [%s]:%u (%s)",
+	    bind_host, cctx->port_orig, scope);
+	return 0;
+}
 
